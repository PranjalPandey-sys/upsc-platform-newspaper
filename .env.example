# UPSC Newspaper Intelligence Engine — Environment Variables
# Copy this file to .env for local development (never commit .env)

# ── Required ───────────────────────────────────────────────────────────────────

# Google Gemini API key (used via OpenAI-compatible endpoint)
GEMINI_API_KEY=your_gemini_api_key_here

# API keys for authenticating Telegram bot and other clients
# Comma-separated. Generate any random string — keep it secret.
# In the Telegram bot, set NEWSPAPER_API_KEY to match one of these.
API_KEYS=change_this_to_a_strong_random_key,optional_second_key

# ── Optional — GitHub backup ───────────────────────────────────────────────────

# GitHub Personal Access Token (repo:write scope)
GITHUB_TOKEN=

# GitHub repo for backups: "username/repo-name"
GITHUB_REPO=

# ── Optional — Tuning ─────────────────────────────────────────────────────────

# Enable debug logging (default: false)
DEBUG=false

# Server port (Render sets this automatically)
PORT=8000
